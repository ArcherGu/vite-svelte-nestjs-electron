{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@render/*": ["./src/render/*"],
      "@main/*": ["./src/main/*"]
    },
    "resolveJsonModule": true,
    "types": ["svelte", "vite/client", "./src/preload"],
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/render/**/*.ts",
    "src/render/**/*.js",
    "src/render/**/*.svelte",
    "src/render/**/*.d.ts",
    "src/main/**/*.types.ts",
    "src/preload/**/*.d.ts"
  ]
}
